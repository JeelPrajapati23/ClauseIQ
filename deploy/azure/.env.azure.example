# Copy this file to deploy/azure/.env.azure (gitignored) and fill in real values.
# Never put real secrets in bootstrap.sh itself — it's tracked by git.
#
# Quote every value in single quotes, with the closing quote immediately after
# the value — no trailing spaces before it, they'd become part of the value
# and break things downstream (e.g. a padded DATABASE_URL fails to connect).
# This file gets `source`d by bash, and connection strings/tokens often
# contain characters bash treats specially if left unquoted — e.g. Neon URLs
# contain "&", which bash reads as "run this assignment in the background"
# and silently discards it instead of setting the variable.

GROQ_API_KEY=''
COHERE_API_KEY=''
JWT_SECRET_KEY=''
# Neon connection string, e.g. 'postgresql://user:pass@host/db?sslmode=require&channel_binding=require'
DATABASE_URL=''
# Qdrant Cloud cluster URL, e.g. 'https://xxxx.aws.cloud.qdrant.io'
QDRANT_URL=''
QDRANT_API_KEY=''
# your Vercel URL, e.g. 'https://clauseiq-rag.vercel.app'
APP_FRONTEND_URL=''

# Optional — leave all five blank to have password-reset links printed to the
# Container App's logs instead of emailed (same fallback as local dev).
SMTP_HOST=''
SMTP_PORT='587'
SMTP_USER=''
SMTP_PASS=''
FROM_EMAIL=''
